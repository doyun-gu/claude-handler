# Machine Role Configuration
# Generated by install.sh — edit as needed
#
# MACHINE_ROLE: commander | worker | hybrid
#   commander — Interactive machine (laptop). Can dispatch tasks to worker.
#   worker    — Autonomous machine (Mac Mini/desktop). Runs tasks from queue.
#   hybrid    — Single machine acting as both commander and worker.
#
# SSH_TARGET: hostname or IP of the worker machine (commander only)
#   Used by /dispatch, /queue, /worker-status commands
#
# DEV_DIR: root directory where projects live
#   Used to locate project repos when running tasks
#
# WORKER_CLAUDE_BIN: path to Claude CLI on worker (worker/hybrid only)
#   Usually $HOME/.local/bin/claude

MACHINE_ROLE=commander
SSH_TARGET=mac-mini
DEV_DIR=$HOME/Developer
WORKER_CLAUDE_BIN=$HOME/.local/bin/claude
