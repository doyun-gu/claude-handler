#!/bin/bash
# post-merge hook for DPSpice-com — Auto-restart services after git pull/merge
# Install: cp hooks/post-merge-dpspice ~/Developer/dynamic-phasors/DPSpice-com/.git/hooks/post-merge
#          chmod +x ~/Developer/dynamic-phasors/DPSpice-com/.git/hooks/post-merge

set -uo pipefail
export PATH=/opt/homebrew/bin:$HOME/.local/bin:$PATH

DPSPICE_DIR="$(git rev-parse --show-toplevel)"
LOG_FILE="$HOME/.claude-fleet/logs/post-merge.log"
mkdir -p "$(dirname "$LOG_FILE")"

log() { echo "[post-merge $(date +%Y-%m-%dT%H:%M:%S)] $1" | tee -a "$LOG_FILE"; }

log "Merge detected in $DPSPICE_DIR"

# ── Always clear .next cache and restart dev server ──
if [ -d "$DPSPICE_DIR/web/.next" ]; then
    rm -rf "$DPSPICE_DIR/web/.next"
    log "Cleared .next cache"
fi

# Restart dev server if running
if tmux has-session -t dpspice-dev 2>/dev/null; then
    tmux kill-session -t dpspice-dev 2>/dev/null
    sleep 1

    # Detect node path
    NODE_BIN=""
    if [ -d "$HOME/.nvm/versions/node" ]; then
        NODE_DIR=$(ls -d "$HOME/.nvm/versions/node"/v* 2>/dev/null | sort -V | tail -1)
        [ -n "$NODE_DIR" ] && NODE_BIN="$NODE_DIR/bin:"
    fi

    tmux new-session -d -s dpspice-dev \
        "cd $DPSPICE_DIR/web && export PATH=${NODE_BIN}/opt/homebrew/bin:\$HOME/.local/bin:\$PATH && npm run dev -- -H 0.0.0.0 -p 3002 2>&1 | tee /tmp/dpspice-dev.log"
    log "Restarted dev server on :3002"
fi

# ── Restart API if Python files changed ──
CHANGED_PY=$(git diff-tree -r --name-only --diff-filter=ACMRT ORIG_HEAD HEAD -- '*.py' 2>/dev/null | head -5)
if [ -n "$CHANGED_PY" ]; then
    log "Python files changed: $(echo "$CHANGED_PY" | tr '\n' ' ')"

    if tmux has-session -t dpspice-api 2>/dev/null; then
        tmux kill-session -t dpspice-api 2>/dev/null
        sleep 1

        VENV_PYTHON="$DPSPICE_DIR/.venv/bin/python"
        [ ! -f "$VENV_PYTHON" ] && VENV_PYTHON="python3"

        tmux new-session -d -s dpspice-api \
            "cd $DPSPICE_DIR && export PYTHONPATH=src/python && $VENV_PYTHON -m uvicorn api.main:app --host 0.0.0.0 --port 8000 2>&1 | tee /tmp/dpspice-api.log"
        log "Restarted API server on :8000"
    fi
fi

log "Post-merge hook complete"
